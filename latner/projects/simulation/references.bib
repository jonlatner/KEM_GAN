@article{reiter2014, title={Bayesian Estimation of Disclosure Risks for Multiply Imputed, Synthetic Data}, volume={6}, url={https://journalprivacyconfidentiality.org/index.php/jpc/article/view/635}, DOI={10.29012/jpc.v6i1.635}, abstractNote={&amp;lt;p&amp;gt;Agencies seeking to disseminate public use microdata, i.e., data on individual records, can replace confidential values with multiple draws from statistical models estimated with the collected data. We present a famework for evaluating disclosure risks inherent in releasing multiply-imputed, synthetic data. The basic idea is to mimic an intruder who computes posterior distributions of confidential values given the released synthetic data and prior knowledge. We illustrate the methodology with artificial fully synthetic data and with partial synthesis of the Survey of Youth in Custody.&amp;lt;/p&amp;gt;}, number={1}, journal={Journal of Privacy and Confidentiality}, author={Reiter, Jerome P. and Wang, Quanli and Zhang, Biyuan}, year={2014}, month={Jun.} }

